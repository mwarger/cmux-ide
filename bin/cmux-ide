#!/usr/bin/env bash
# cmux-ide — Modular IDE-like workspace launcher for cmux
# Usage: cmux-ide [--profile NAME] [project-path]
#        cmux-ide              (interactive menu)
#        cmux-ide --add-fav    (add current dir to favorites)
#        cmux-ide --rm-fav     (remove a favorite)
#        cmux-ide --list-fav   (list favorites)

set -uo pipefail

CONFIG_DIR="$HOME/.config/cmux-ide"
FAVORITES_FILE="$CONFIG_DIR/favorites"
RECENTS_FILE="$CONFIG_DIR/recents"
PROJECTS_DIR="${CMUX_IDE_PROJECTS_DIR:-$HOME/dev}"
MAX_RECENTS=10

mkdir -p "$CONFIG_DIR"
touch "$FAVORITES_FILE" "$RECENTS_FILE"

# --- helpers ---

add_recent() {
  local dir="$1"
  grep -v "^${dir}$" "$RECENTS_FILE" 2>/dev/null > "$RECENTS_FILE.tmp" || true
  { echo "$dir"; head -n $((MAX_RECENTS - 1)) "$RECENTS_FILE.tmp"; } > "$RECENTS_FILE"
  rm -f "$RECENTS_FILE.tmp"
}

print_menu() {
  local i=1

  if [[ -s "$FAVORITES_FILE" ]]; then
    echo ""
    echo "  ⭐ Favorites"
    echo "  ──────────────────────────────"
    while IFS= read -r fav; do
      [[ -z "$fav" ]] && continue
      local name
      name=$(basename "$fav")
      printf "  %2d) %s\n" "$i" "$name"
      CHOICES[$i]="$fav"
      ((i++))
    done < "$FAVORITES_FILE"
  fi

  if [[ -s "$RECENTS_FILE" ]]; then
    echo ""
    echo "  🕐 Recent"
    echo "  ──────────────────────────────"
    while IFS= read -r rec; do
      [[ -z "$rec" ]] && continue
      grep -qx "$rec" "$FAVORITES_FILE" 2>/dev/null && continue
      local name
      name=$(basename "$rec")
      printf "  %2d) %s\n" "$i" "$name"
      CHOICES[$i]="$rec"
      ((i++))
    done < "$RECENTS_FILE"
  fi

  if [[ -d "$PROJECTS_DIR" ]]; then
    echo ""
    echo "  📁 Projects"
    echo "  ──────────────────────────────"
    for dir in "$PROJECTS_DIR"/*/; do
      [[ ! -d "$dir" ]] && continue
      local name
      name=$(basename "$dir")
      local already=false
      for existing in "${CHOICES[@]+"${CHOICES[@]}"}"; do
        [[ "$existing" == "${dir%/}" ]] && already=true && break
      done
      $already && continue
      printf "  %2d) %s\n" "$i" "$name"
      CHOICES[$i]="${dir%/}"
      ((i++))
    done
  fi

  echo ""
  echo "   p) Enter path manually"
  echo "   f) Add current dir to favorites"
  echo "   q) Quit"
  echo ""
}

# --- launch ---

launch_workspace() {
  local project_dir="$1"

  if [[ ! -d "$project_dir" ]]; then
    echo "Error: $project_dir does not exist"
    exit 1
  fi

  local project_name
  project_name=$(basename "$project_dir")

  add_recent "$project_dir"

  echo ""
  echo "  Launching workspace: $project_name"
  echo "  ─────────────────────────────────────"

  # 1. Create workspace
  local ws_ref
  ws_ref=$(cmux new-workspace --cwd "$project_dir" 2>&1 | grep -oE 'workspace:[0-9]+' | head -1) || ws_ref=""
  if [[ -z "$ws_ref" ]]; then
    echo "  Error: Failed to create workspace"
    return 1
  fi

  sleep 0.5
  cmux rename-workspace --workspace "$ws_ref" "$project_name"

  # 2. Discover left surface
  local left_surface
  left_surface=$(cmux send --workspace "$ws_ref" " " 2>&1 | grep -oE 'surface:[0-9]+' | head -1) || left_surface=""
  cmux send-key --workspace "$ws_ref" BackSpace 2>/dev/null || true

  # 3. Split right (creates empty right pane for cy to populate)
  cmux new-split right --workspace "$ws_ref" 2>/dev/null || true

  sleep 0.3

  # 4. Rename left tab and launch cy with /setup-workspace
  if [[ -n "$left_surface" ]]; then
    cmux rename-tab --workspace "$ws_ref" --surface "$left_surface" "Claude Code" 2>/dev/null || true
    cmux send --workspace "$ws_ref" --surface "$left_surface" "cd '$project_dir' && cy /setup-workspace"
    cmux send-key --workspace "$ws_ref" --surface "$left_surface" Return
  fi

  # 5. Select the new workspace
  cmux select-workspace --workspace "$ws_ref"

  echo ""
  echo "  ✓ Workspace created: $project_name"
  echo "    Claude Code is setting up the environment..."
  echo ""
}

# --- subcommands ---

case "${1:-}" in
  --add-fav)
    dir="${2:-$(pwd)}"
    dir=$(cd "$dir" && pwd)
    if grep -qx "$dir" "$FAVORITES_FILE" 2>/dev/null; then
      echo "Already a favorite: $(basename "$dir")"
    else
      echo "$dir" >> "$FAVORITES_FILE"
      echo "Added favorite: $(basename "$dir")"
    fi
    exit 0
    ;;
  --rm-fav)
    if [[ ! -s "$FAVORITES_FILE" ]]; then
      echo "No favorites saved."
      exit 0
    fi
    echo "Remove which favorite?"
    i=1
    declare -A RM_CHOICES
    while IFS= read -r fav; do
      [[ -z "$fav" ]] && continue
      printf "  %d) %s\n" "$i" "$(basename "$fav")"
      RM_CHOICES[$i]="$fav"
      ((i++))
    done < "$FAVORITES_FILE"
    printf "\n  Choice: "
    read -r choice
    if [[ -n "${RM_CHOICES[$choice]:-}" ]]; then
      grep -v "^${RM_CHOICES[$choice]}$" "$FAVORITES_FILE" > "$FAVORITES_FILE.tmp"
      mv "$FAVORITES_FILE.tmp" "$FAVORITES_FILE"
      echo "Removed: $(basename "${RM_CHOICES[$choice]}")"
    fi
    exit 0
    ;;
  --list-fav)
    echo "Favorites:"
    cat "$FAVORITES_FILE"
    exit 0
    ;;
  --help|-h)
    echo "cmux-ide — Modular IDE workspace launcher for cmux"
    echo ""
    echo "Usage:"
    echo "  cmux-ide                  Interactive project picker"
    echo "  cmux-ide <path>           Launch workspace"
    echo "  cmux-ide --add-fav [dir]  Add directory to favorites"
    echo "  cmux-ide --rm-fav         Remove a favorite"
    echo "  cmux-ide --list-fav       List favorites"
    echo ""
    echo "cy launches with /setup-workspace to dynamically configure surfaces."
    exit 0
    ;;
  "")
    # Interactive mode — fall through to menu
    ;;
  *)
    launch_workspace "$(cd "$1" && pwd)"
    exit 0
    ;;
esac

# --- interactive menu ---

declare -A CHOICES

echo ""
echo "  cmux-ide — Project Workspace Launcher"
echo "  ═══════════════════════════════════════"

print_menu

printf "  Choice: "
read -r choice

case "$choice" in
  q|Q)
    exit 0
    ;;
  p|P)
    printf "  Path: "
    read -r custom_path
    custom_path="${custom_path/#\~/$HOME}"
    launch_workspace "$(cd "$custom_path" && pwd)"
    ;;
  f|F)
    dir="$(pwd)"
    if grep -qx "$dir" "$FAVORITES_FILE" 2>/dev/null; then
      echo "Already a favorite: $(basename "$dir")"
    else
      echo "$dir" >> "$FAVORITES_FILE"
      echo "Added favorite: $(basename "$dir")"
    fi
    ;;
  *)
    if [[ -n "${CHOICES[$choice]:-}" ]]; then
      launch_workspace "${CHOICES[$choice]}"
    else
      echo "Invalid choice"
      exit 1
    fi
    ;;
esac
