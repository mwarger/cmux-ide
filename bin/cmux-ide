#!/usr/bin/env bash
# cmux-ide — Modular IDE-like workspace launcher for cmux
# Usage: cmux-ide [project-path]   (defaults to current directory)

set -uo pipefail

CONFIG_DIR="$HOME/.config/cmux-ide"
mkdir -p "$CONFIG_DIR"

# --- agent resolution ---

resolve_agent() {
  local project_dir="${1:-}"

  # 1. Env var override
  if [[ -n "${CMUX_IDE_AGENT:-}" ]]; then
    echo "$CMUX_IDE_AGENT"
    return
  fi

  # 2. Per-project override (.cmux-ide.json "agent" field)
  if [[ -n "$project_dir" && -f "$project_dir/.cmux-ide.json" ]]; then
    local proj_agent
    proj_agent=$(python3 -c "import json; print(json.load(open('$project_dir/.cmux-ide.json')).get('agent',''))" 2>/dev/null) || proj_agent=""
    if [[ -n "$proj_agent" ]]; then
      echo "$proj_agent"
      return
    fi
  fi

  # 3. Global config
  if [[ -f "$CONFIG_DIR/agent" ]]; then
    local global_agent
    global_agent=$(head -1 "$CONFIG_DIR/agent")
    if [[ -n "$global_agent" ]]; then
      echo "$global_agent"
      return
    fi
  fi

  # 4. First-run prompt — only if interactive terminal
  if [[ ! -t 0 ]]; then
    # Non-interactive: default to claude silently
    echo "claude" > "$CONFIG_DIR/agent"
    echo "claude"
    return
  fi

  echo "" >&2
  echo "  ┌─────────────────────────────────────────────┐" >&2
  echo "  │  First-run setup: Which AI agent do you use? │" >&2
  echo "  ├─────────────────────────────────────────────┤" >&2
  echo "  │  1) claude    (Claude Code)                  │" >&2
  echo "  │  2) codex     (OpenAI Codex CLI)             │" >&2
  echo "  │  3) opencode  (OpenCode)                     │" >&2
  echo "  │  4) pi        (Pi)                           │" >&2
  echo "  │  5) Other     (enter command)                │" >&2
  echo "  └─────────────────────────────────────────────┘" >&2
  echo "" >&2
  printf "  Choice [1]: " >&2
  read -r agent_choice </dev/tty

  local agent
  case "${agent_choice:-1}" in
    1|"") agent="claude" ;;
    2) agent="codex" ;;
    3) agent="opencode" ;;
    4) agent="pi" ;;
    *)
      printf "  Agent command: " >&2
      read -r agent </dev/tty
      ;;
  esac

  echo "$agent" > "$CONFIG_DIR/agent"
  echo "" >&2
  echo "  Saved: $agent (change anytime in ~/.config/cmux-ide/agent)" >&2
  echo "" >&2
  echo "$agent"
}

# --- launch ---

launch_workspace() {
  local project_dir="$1"

  if [[ ! -d "$project_dir" ]]; then
    echo "Error: $project_dir does not exist"
    exit 1
  fi

  local project_name
  project_name=$(basename "$project_dir")

  local agent
  agent=$(resolve_agent "$project_dir")

  echo ""
  echo "  Launching workspace: $project_name (agent: $agent)"
  echo "  ─────────────────────────────────────"

  # 1. Create workspace
  local ws_ref
  ws_ref=$(cmux new-workspace --cwd "$project_dir" 2>&1 | grep -oE 'workspace:[0-9]+' | head -1) || ws_ref=""
  if [[ -z "$ws_ref" ]]; then
    echo "  Error: Failed to create workspace"
    return 1
  fi

  sleep 0.5
  cmux rename-workspace --workspace "$ws_ref" "$project_name"

  # 2. Discover left surface
  local left_surface
  left_surface=$(cmux send --workspace "$ws_ref" " " 2>&1 | grep -oE 'surface:[0-9]+' | head -1) || left_surface=""
  cmux send-key --workspace "$ws_ref" BackSpace 2>/dev/null || true

  # 3. Set initial progress indicator
  cmux set-progress 0.0 --label "Starting setup..." --workspace "$ws_ref" 2>/dev/null || true

  # 4. Phase 1: Analyze workspace — Haiku for claude, default plan for others
  local plan_json
  if [[ "$agent" == "claude" ]]; then
    plan_json=$("$HOME/bin/cmux-ide-modules/analyze-workspace.sh" "$project_dir") || \
      plan_json='{"tabs":[{"label":"gitui","command":"gitui"},{"label":"terminal","command":""}],"browser":null}'
  else
    plan_json='{"tabs":[{"label":"gitui","command":"gitui"},{"label":"terminal","command":""}],"browser":null}'
  fi

  # 5. Phase 2: Execute — create all surfaces mechanically
  echo "$plan_json" | "$HOME/bin/cmux-ide-modules/create-surfaces.sh" "$ws_ref" "$project_dir"

  # 6. Launch agent in left pane
  if [[ -n "$left_surface" ]]; then
    cmux rename-tab --workspace "$ws_ref" --surface "$left_surface" "$agent" 2>/dev/null || true
    if [[ "$agent" == "claude" ]]; then
      cmux send --workspace "$ws_ref" --surface "$left_surface" "cd '$project_dir' && claude --dangerously-skip-permissions"
    else
      cmux send --workspace "$ws_ref" --surface "$left_surface" "cd '$project_dir' && $agent"
    fi
    cmux send-key --workspace "$ws_ref" --surface "$left_surface" Return
  fi

  # 7. Select the new workspace
  cmux select-workspace --workspace "$ws_ref"

  echo ""
  echo "  ✓ Workspace ready: $project_name (agent: $agent)"
  echo ""
}

# --- main ---

case "${1:-}" in
  --help|-h)
    echo "cmux-ide — IDE workspace launcher for cmux"
    echo ""
    echo "Usage:"
    echo "  cmux-ide              Launch workspace for current directory"
    echo "  cmux-ide <path>       Launch workspace for specified path"
    echo ""
    echo "Agent config: CMUX_IDE_AGENT env var > .cmux-ide.json > ~/.config/cmux-ide/agent"
    echo "Workspace tabs are created automatically before the agent launches."
    echo "Claude projects use Haiku to detect dev servers; other agents get gitui + terminal."
    exit 0
    ;;
  "")
    launch_workspace "$(pwd)"
    ;;
  *)
    launch_workspace "$(cd "$1" && pwd)"
    ;;
esac
